# =============================================================================
# Intrex Digital Hub — Environment Configuration
# Copy this file to .env and update the values for your environment.
# =============================================================================

# --- Django Core ---
DJANGO_SECRET_KEY=generate-a-long-random-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=app.dremotic.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://app.dremotic.com
DJANGO_LOG_LEVEL=INFO

# --- Admin Bootstrap (first-run only) ---
ADMIN_PASSWORD=your-strong-admin-password
ADMIN_EMAIL=admin@yourdomain.com

# --- MySQL Database ---
DB_ENGINE=django.db.backends.mysql
DB_NAME=intrex_digital_hub
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_HOST=localhost
DB_PORT=3306

# --- Redis / Celery (optional — omit on cPanel shared hosting) ---
# CELERY_BROKER_URL=redis://localhost:6379/0
# CELERY_RESULT_BACKEND=redis://localhost:6379/0
# REDIS_URL=redis://localhost:6379/0

# --- Sentry Error Tracking (optional) ---
# SENTRY_DSN=https://your-dsn@sentry.io/project-id
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- cPanel: disable Django SSL redirect (Apache handles SSL) ---
DISABLE_SSL_REDIRECT=True

# --- Vite Frontend Dev Server (development only) ---
# VITE_DEV_URL=http://localhost:5173
