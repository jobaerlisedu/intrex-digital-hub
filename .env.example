# Django Core
DJANGO_SECRET_KEY=generate-a-long-random-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
DJANGO_LOG_LEVEL=INFO

# Firebase (recommended: paste full service account JSON as single line)
FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# Firebase (alternative: path to credentials file, relative to project root)
# FIREBASE_CREDENTIALS_PATH=firebase-credentials.json

# Admin bootstrap
ADMIN_PASSWORD=your-strong-admin-password
ADMIN_EMAIL=admin@yourdomain.com

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Redis (for caching — optional, falls back to LocMemCache)
REDIS_URL=redis://localhost:6379/0

# Sentry error tracking (optional)
SENTRY_DSN=https://your-dsn@sentry.io/project-id
SENTRY_TRACES_SAMPLE_RATE=0.1

# MySQL Database (uncomment to switch from SQLite to MySQL)
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=intrex_digital_hub
# DB_USER=root
# DB_PASSWORD=your-mysql-password
# DB_HOST=localhost
# DB_PORT=3306

# Render (optional, set by platform)
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
